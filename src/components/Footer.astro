---
import { type Lang, useTranslations, localizedPath } from "../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <span>© {year} Sangyun Lee · <a href={localizedPath("/personal", lang)}>{t("nav.personal")}</a></span>
    <span>{t("footer.builtWith")} {t("footer.hostedBy")}</span>
  </div>
</footer>
