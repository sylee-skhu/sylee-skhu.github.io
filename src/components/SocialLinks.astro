---

<div class="socials">
  {
    socials.map((s) => (
      <a
        href={s.href}
        class="social"
        aria-label={s.name}
        title={s.name}
        target={s.icon === "email" ? undefined : "_blank"}
        rel={s.icon === "email" ? undefined : "noopener noreferrer"}
      >
        <Fragment set:html={ICONS[s.icon]} />
      </a>
    ))
  }
</div>

<style>
  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.1rem;
  }
  .social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-muted);
    background: var(--bg-elevated);
    transition: color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .social:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .social :global(svg) {
    width: 19px;
    height: 19px;
  }
</style>
