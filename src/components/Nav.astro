---
import { type Lang, useTranslations, localizedPath, pick } from "../i18n/ui";
import { site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";
import LanguageToggle from "./LanguageToggle.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const items = [
  { key: "nav.publications", path: "/publications" },
  { key: "nav.projects", path: "/projects" },
  { key: "nav.people", path: "/people" },
  { key: "nav.courses", path: "/courses" },
  { key: "nav.news", path: "/news" },
  { key: "nav.hobbies", path: "/hobbies" },
] as const;

const current = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (path: string) => {
  const target = localizedPath(path, lang).replace(/\/+$/, "") || "/";
  return current === target || current.startsWith(target + "/");
};

const cvHref = pick(site.cvPdf, lang);
---

<header class="nav">
  <nav class="nav-inner" aria-label="Main">
    <a class="nav-brand" href={localizedPath("/", lang)}>{pick(site.name, lang)}</a>
    <div class="nav-links">
      {
        items.map((it) => (
          <a href={localizedPath(it.path, lang)} aria-current={isActive(it.path) ? "page" : undefined}>
            {t(it.key)}
          </a>
        ))
      }
    </div>
    <div class="nav-tools">
      <a
        class="icon-btn cv-btn"
        href={cvHref}
        target="_blank"
        rel="noopener noreferrer"
        title={t("cv.download")}
        aria-label={t("cv.download")}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span>{t("nav.cv")}</span>
      </a>
      <LanguageToggle lang={lang} />
      <ThemeToggle lang={lang} />
    </div>
  </nav>
</header>

<style>
  .cv-btn {
    width: auto;
    gap: 0.3rem;
    padding: 0 0.6rem;
  }
  .cv-btn svg {
    width: 15px;
    height: 15px;
  }
  .cv-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>
