---
import type { NewsItem } from "../data/news";
import type { Lang } from "../i18n/ui";

interface Props {
  items: NewsItem[];
  lang: Lang;
}
const { items, lang } = Astro.props;
const fmt = new Intl.DateTimeFormat(lang === "ko" ? "ko-KR" : "en-US", {
  year: "numeric",
  month: "short",
});
---

<ul class="news-list">
  {
    items.map((n) => (
      <li class={`news-item ${n.type}`}>
        <time class="news-date" datetime={n.date}>
          {fmt.format(new Date(n.date))}
        </time>
        <p class="news-text">{lang === "ko" ? n.ko : n.en}</p>
      </li>
    ))
  }
</ul>

<style>
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .news-item {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 0.75rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--border);
  }
  .news-item:last-child {
    border-bottom: none;
  }
  .news-date {
    color: var(--text-muted);
    font-size: 0.82rem;
    font-variant-numeric: tabular-nums;
    padding-top: 0.1rem;
    white-space: nowrap;
  }
  .news-text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    position: relative;
  }
  .news-text::before {
    content: "";
    position: absolute;
    left: -0.78rem;
    top: 0.55rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }
  .news-item.project .news-text::before {
    background: #16a34a;
  }
  @media (max-width: 540px) {
    .news-item {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
    .news-text::before {
      display: none;
    }
  }
</style>
