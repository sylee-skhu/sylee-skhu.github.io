---
import { type Lang, useTranslations } from "../../i18n/ui";
import PersonCard from "../PersonCard.astro";
import { people } from "../../data/people";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const pis = people.filter((p) => p.role === "pi");
const members = people.filter((p) => p.role === "phd" || p.role === "ms" || p.role === "undergrad");
const alumni = people.filter((p) => p.role === "alumni");
---

<div class="page-header">
  <h1>{t("people.title")}</h1>
  <p>{t("people.description")}</p>
</div>

<section class="section">
  <div class="section-head">
    <h2>{t("people.pi")}</h2>
  </div>
  <div class="people-grid">
    {pis.map((p) => <PersonCard person={p} lang={lang} />)}
  </div>
</section>

{
  members.length > 0 && (
    <section class="section">
      <div class="section-head">
        <h2>{t("people.members")}</h2>
      </div>
      <div class="people-grid">
        {members.map((p) => (
          <PersonCard person={p} lang={lang} />
        ))}
      </div>
    </section>
  )
}

{
  alumni.length > 0 && (
    <section class="section">
      <div class="section-head">
        <h2>{t("people.alumni")}</h2>
      </div>
      <div class="people-grid">
        {alumni.map((p) => (
          <PersonCard person={p} lang={lang} />
        ))}
      </div>
    </section>
  )
}

<section class="section">
  <div class="join-card">
    <h2>{t("people.join")}</h2>
    <p>{t("people.joinText")}</p>
    <div class="join-actions">
      <a class="btn" href="/recruit.html">{t("people.recruitCta")}</a>
      <a class="btn btn-ghost" href="/program.html">{t("people.programCta")}</a>
    </div>
  </div>
</section>

<style>
  .people-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1.75rem 1.25rem;
  }
  .join-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--accent-soft);
    padding: 1.75rem 1.9rem;
  }
  .join-card h2 {
    margin: 0 0 0.5rem;
  }
  .join-card > p {
    margin: 0 0 1.15rem;
    color: var(--text);
    max-width: 62ch;
  }
  .join-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
</style>
