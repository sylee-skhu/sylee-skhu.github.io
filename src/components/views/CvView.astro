---
import { type Lang, useTranslations, pick } from "../../i18n/ui";
import { education, experience, awards, interests } from "../../data/cv";
import { site } from "../../data/site";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const present = t("common.present");
const fp = (s: string) => s.replace(/present/i, present);
const cvHref = pick(site.cvPdf, lang);
---

<div class="page-header cv-header">
  <h1>{t("cv.title")}</h1>
  <a class="btn" href={cvHref} target="_blank" rel="noopener noreferrer">{t("cv.download")}</a>
</div>

<section class="section">
  <div class="section-head"><h2>{t("cv.education")}</h2></div>
  {
    education.map((e) => (
      <div class="cv-item">
        <div class="cv-when">{fp(e.period)}</div>
        <div class="cv-what">
          <h3>{pick(e.degree, lang)}</h3>
          <p class="muted">{pick(e.institution, lang)}</p>
          {e.notes && (
            <ul class="cv-notes">
              {e.notes.map((n) => (
                <li>
                  <strong>{pick(n.label, lang)}:</strong>{" "}
                  {n.href ? (
                    <a href={n.href} target="_blank" rel="noopener noreferrer">{pick(n.value, lang)}</a>
                  ) : (
                    pick(n.value, lang)
                  )}
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    ))
  }
</section>

<section class="section">
  <div class="section-head"><h2>{t("cv.experience")}</h2></div>
  {
    experience.map((e) => (
      <div class="cv-item">
        <div class="cv-when">{fp(e.period)}</div>
        <div class="cv-what">
          <h3>{pick(e.role, lang)}</h3>
          <p class="muted">{pick(e.org, lang)}</p>
          {e.notes && (
            <ul class="cv-notes">
              {e.notes.map((n) => (
                <li>{pick(n, lang)}</li>
              ))}
            </ul>
          )}
        </div>
      </div>
    ))
  }
</section>

<section class="section">
  <div class="section-head"><h2>{t("cv.awards")}</h2></div>
  {
    awards.map((a) => (
      <div class="cv-item">
        <div class="cv-when">{a.year}</div>
        <div class="cv-what">
          <ul class="cv-notes plain">
            {a.items.map((i) => (
              <li>{pick(i, lang)}</li>
            ))}
          </ul>
        </div>
      </div>
    ))
  }
</section>

<section class="section">
  <div class="section-head"><h2>{t("cv.interests")}</h2></div>
  <div class="interest-grid">
    {
      interests.map((g) => (
        <div class="interest">
          <h3>{pick(g.area, lang)}</h3>
          <ul>
            {g.items.map((i) => (
              <li>{pick(i, lang)}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>

<style>
  .cv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .cv-item {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
  }
  .cv-when {
    color: var(--text-muted);
    font-size: 0.84rem;
    font-variant-numeric: tabular-nums;
    padding-top: 0.15rem;
  }
  .cv-what h3 {
    font-size: 1rem;
    margin: 0 0 0.15rem;
  }
  .cv-what > p {
    margin: 0;
  }
  .cv-notes {
    margin: 0.45rem 0 0;
    padding-left: 1.1rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .cv-notes.plain {
    list-style: none;
    padding-left: 0;
    margin-top: 0;
  }
  .interest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.2rem;
  }
  .interest h3 {
    font-size: 1rem;
    margin-bottom: 0.3rem;
  }
  .interest ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }
  @media (max-width: 540px) {
    .cv-item {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
  }
</style>
