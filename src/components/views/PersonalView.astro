---
import { Image } from "astro:assets";
import { type Lang, useTranslations, pick } from "../../i18n/ui";
import { personal } from "../../data/personal";
import { getPersonalImage } from "../../lib/images";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const dfmt = new Intl.DateTimeFormat(lang === "ko" ? "ko-KR" : "en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const items = personal
  .map((it) => ({ ...it, img: getPersonalImage(it.image) }))
  .filter((it): it is typeof it & { img: NonNullable<typeof it.img> } => Boolean(it.img));
---

<div class="page-header">
  <h1>{t("personal.title")}</h1>
  <p>{t("personal.description")}</p>
</div>

<div class="gallery">
  {
    items.map((it) => (
      <a class="gal-item" href={it.img.src} target="_blank" rel="noopener noreferrer">
        <Image src={it.img} width={560} alt={pick(it.title, lang)} loading="lazy" />
        <div class="gal-cap">
          <span class="gal-title">
            {pick(it.title, lang)}
            {it.subtitle ? ` · ${pick(it.subtitle, lang)}` : ""}
          </span>
          <time class="muted" datetime={it.date}>{dfmt.format(new Date(it.date))}</time>
        </div>
      </a>
    ))
  }
</div>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .gal-item {
    display: block;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-elevated);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .gal-item:hover {
    text-decoration: none;
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .gal-item :global(img) {
    width: 100%;
    height: 175px;
    object-fit: cover;
    display: block;
  }
  .gal-cap {
    padding: 0.6rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .gal-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }
  .gal-cap time {
    font-size: 0.78rem;
  }
</style>
