---
import { Image } from "astro:assets";
import { type Lang, useTranslations, pick, localizedPath } from "../../i18n/ui";
import type { Hobby } from "../../data/hobbies";
import { personal } from "../../data/personal";
import { getPersonalImage } from "../../lib/images";

interface Props {
  hobby: Hobby;
  lang: Lang;
}
const { hobby, lang } = Astro.props;
const t = useTranslations(lang);
const dfmt = new Intl.DateTimeFormat(lang === "ko" ? "ko-KR" : "en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const photos = hobby.gallery
  ? personal
      .filter((p) => p.category === hobby.gallery)
      .map((it) => ({ ...it, img: getPersonalImage(it.image) }))
      .filter((it): it is typeof it & { img: NonNullable<typeof it.img> } => Boolean(it.img))
  : [];

const desc = hobby.description ? pick(hobby.description, lang) : "";
const paragraphs = desc ? desc.split(/\n\s*\n/).map((s) => s.trim()).filter(Boolean) : [];
---

<p class="back"><a href={localizedPath("/hobbies", lang)}>← {t("hobbies.back")}</a></p>

<div class="page-header">
  <h1><span class="hb-emoji">{hobby.emoji}</span> {pick(hobby.name, lang)}</h1>
  {hobby.note && <p class="muted">{pick(hobby.note, lang)}</p>}
</div>

{paragraphs.map((p) => <p>{p}</p>)}

{
  photos.length > 0 && (
    <div class="gallery">
      {photos.map((it) => (
        <a class="gal-item" href={it.img.src} target="_blank" rel="noopener noreferrer">
          <Image src={it.img} width={560} alt={pick(it.title, lang)} loading="lazy" />
          <div class="gal-cap">
            <span class="gal-title">
              {pick(it.title, lang)}
              {it.subtitle ? ` · ${pick(it.subtitle, lang)}` : ""}
            </span>
            <time class="muted" datetime={it.date}>{dfmt.format(new Date(it.date))}</time>
          </div>
        </a>
      ))}
    </div>
  )
}

<style>
  .back {
    margin-bottom: 1rem;
    font-size: 0.88rem;
  }
  .hb-emoji {
    margin-right: 0.3rem;
  }
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .gal-item {
    display: block;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-elevated);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .gal-item:hover {
    text-decoration: none;
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .gal-item :global(img) {
    width: 100%;
    height: 175px;
    object-fit: cover;
    display: block;
  }
  .gal-cap {
    padding: 0.6rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .gal-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }
  .gal-cap time {
    font-size: 0.78rem;
  }
</style>
