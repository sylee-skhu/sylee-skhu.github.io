---
import { type Lang, useTranslations, pick, localizedPath } from "../../i18n/ui";
import type { ResearchTopic } from "../../data/research";
import { videoEmbedUrl } from "../../data/research";

interface Props {
  topic: ResearchTopic;
  lang: Lang;
}
const { topic, lang } = Astro.props;
const t = useTranslations(lang);
const desc = pick(topic.description, lang);
const paragraphs = desc.split(/\n\s*\n/).map((s) => s.trim()).filter(Boolean);
const videos = topic.videos ?? [];
---

<p class="back"><a href={localizedPath("/research", lang)}>← {t("research.back")}</a></p>

<div class="page-header">
  <h1>{pick(topic.title, lang)}</h1>
</div>

{
  videos.length > 0 ? (
    <div class="videos">
      {videos.map((v) => (
        <figure class="video-item">
          <div class="video-embed">
            <iframe
              src={videoEmbedUrl(v)}
              title={pick(topic.title, lang)}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
          {v.caption && <figcaption>{pick(v.caption, lang)}</figcaption>}
        </figure>
      ))}
    </div>
  ) : (
    <div class="video-ph">{t("research.videoSoon")}</div>
  )
}

<div class="detail-body">
  {paragraphs.map((p) => <p>{p}</p>)}
</div>

<style>
  .back {
    margin-bottom: 1rem;
    font-size: 0.88rem;
  }
  .videos {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .video-item {
    margin: 0;
  }
  .video-embed {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #000;
  }
  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .video-item figcaption {
    margin-top: 0.5rem;
    font-size: 0.88rem;
    color: var(--text-muted);
    text-align: center;
  }
  .video-ph {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    background: var(--bg-soft);
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .detail-body p {
    font-size: 1rem;
  }
</style>
